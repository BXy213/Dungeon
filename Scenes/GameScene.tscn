[sub_resource type="GDScript" id="GDScript_skill_overlay"]
script/source = "extends ColorRect

var skill_ready_color = Color(1, 1, 1, 0.2)  # 技能就绪时的亮色叠加
var skill_cooldown_color = Color(0, 0, 0, 0.6)  # 技能冷却时的暗色叠加
var skill_disabled_color = Color(0, 0, 0, 0.8)  # 技能禁用时的更暗叠加

func set_skill_state(state: String):
	match state:
		\"ready\":
			color = skill_ready_color
		\"cooldown\":
			color = skill_cooldown_color  
		\"disabled\":
			color = skill_disabled_color
		\"normal\":
			color = Color(0, 0, 0, 0)
"

