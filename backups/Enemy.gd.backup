extends CharacterBody2D

@export var health: int = 100
@export var max_health: int = 100
@export var speed: float = 50.0
@export var attack_damage: int = 15
@export var attack_range: float = 50.0
@export var attack_cooldown: float = 2.0

@onready var health_bar = $HealthBar
@onready var health_fill = $HealthBar/HealthFill
@onready var sprite = $Sprite2D

var player: Node2D
var is_dead: bool = false
var can_attack: bool = true

func _ready() -> void:
	add_to_group("enemies")
	player = get_tree().current_scene.get_node("Player")
	update_health_bar()

func _physics_process(_delta: float) -> void:
	if is_dead or not player:
		return
		
	var distance_to_player = global_position.distance_to(player.global_position)
	
	# 如果在攻击范围内，攻击玩家
	if distance_to_player <= attack_range:
		velocity = Vector2.ZERO
		if can_attack:
			# 显示攻击预警
			show_attack_warning()
			# 短暂延迟后攻击，给玩家反应时间
			await get_tree().create_timer(0.5).timeout
			if can_attack:  # 再次检查，可能玩家已经离开范围
				attack_player()
	else:
		# 否则向玩家移动
		var direction = (player.global_position - global_position).normalized()
		velocity = direction * speed
	
	move_and_slide()

func attack_player() -> void:
	if not can_attack or not player:
		return
		
	# 创建攻击弹道
	launch_projectile()
	can_attack = false
	
	# 攻击动画 - 短暂放大和颜色变化
	var tween = create_tween()
	tween.parallel().tween_property(sprite, "scale", Vector2(0.6, 0.6), 0.1)
	tween.parallel().tween_property(sprite, "modulate", Color.RED, 0.1)
	tween.tween_property(sprite, "scale", Vector2(0.5, 0.5), 0.1)
	tween.tween_property(sprite, "modulate", Color(1, 0.5, 0.5), 0.1)
	
	# 攻击冷却
	await get_tree().create_timer(attack_cooldown).timeout
	can_attack = true

func launch_projectile() -> void:
	var projectile_scene = preload("res://Scenes/EnemyProjectile.tscn")
	var projectile = projectile_scene.instantiate()
	
	# 设置弹道起始位置和目标
	var start_pos = global_position
	var target_pos = player.global_position
	
	# 获取当前房间ID
	var current_room_id = Vector2i.ZERO
	var dungeon_generator = get_tree().current_scene.get_node_or_null("DungeonGenerator")
	if dungeon_generator:
		current_room_id = dungeon_generator.get_current_room_coord()
	
	# 添加到场景
	var skill_effects = get_tree().current_scene.get_node_or_null("SkillEffects")
	if skill_effects:
		skill_effects.add_child(projectile)
		
		# 配置弹道，包含房间ID
		projectile.setup(start_pos, target_pos, attack_damage, current_room_id)
		
		print("敌人发射弹道攻击玩家 (房间: ", current_room_id, ")")
	else:
		projectile.queue_free()
		print("错误：找不到技能效果容器")

func show_attack_warning() -> void:
	# 创建攻击预警效果
	var warning_tween = create_tween()
	
	# 敌人闪烁警告
	for i in range(3):
		warning_tween.tween_property(sprite, "modulate", Color.YELLOW, 0.1)
		warning_tween.tween_property(sprite, "modulate", Color(1, 0.5, 0.5), 0.1)
	
	# 在敌人头顶显示感叹号效果
	create_warning_indicator()
	
	print("敌人准备攻击，显示预警!")

func create_warning_indicator() -> void:
	# 创建警告指示器
	var warning_label = Label.new()
	warning_label.text = "!"
	warning_label.add_theme_font_size_override("font_size", 24)
	warning_label.modulate = Color.RED
	warning_label.position = Vector2(-10, -60)
	add_child(warning_label)
	
	# 警告指示器动画
	var indicator_tween = create_tween()
	indicator_tween.tween_property(warning_label, "position", Vector2(-10, -80), 0.3)
	indicator_tween.parallel().tween_property(warning_label, "modulate:a", 0.0, 0.5)
	
	# 动画结束后删除
	await indicator_tween.finished
	warning_label.queue_free()

func take_damage(amount: int) -> void:
	if is_dead:
		return
		
	health -= amount
	print("敌人受到 ", amount, " 点伤害，剩余血量: ", health)
	
	# 受伤闪烁效果
	var tween = create_tween()
	tween.tween_property(sprite, "modulate", Color.RED, 0.1)
	tween.tween_property(sprite, "modulate", Color.WHITE, 0.1)
	
	update_health_bar()
	
	if health <= 0:
		die()

func heal(amount: int) -> void:
	if is_dead:
		return
		
	health = min(health + amount, max_health)
	print("敌人恢复 ", amount, " 点生命值，当前血量: ", health)
	update_health_bar()

func die() -> void:
	is_dead = true
	print("敌人死亡!")
	
	# 死亡动画
	var tween = create_tween()
	tween.parallel().tween_property(self, "modulate:a", 0.0, 1.0)
	tween.parallel().tween_property(self, "scale", Vector2.ZERO, 1.0)
	await tween.finished
	queue_free()

func update_health_bar() -> void:
	if health_fill:
		var health_percent = float(health) / float(max_health)
		health_fill.scale.x = health_percent
		
		# 血条颜色变化
		if health_percent > 0.6:
			health_fill.color = Color.GREEN
		elif health_percent > 0.3:
			health_fill.color = Color.YELLOW
		else:
			health_fill.color = Color.RED

func reset_health() -> void:
	health = max_health
	is_dead = false
	can_attack = true
	
	# 重置外观
	modulate.a = 1.0
	scale = Vector2(0.5, 0.5)  # 恢复敌人原始大小
	visible = true
	
	# 重新启用物理和碰撞
	set_physics_process(true)
	
	update_health_bar()
	print("敌人血量重置")
