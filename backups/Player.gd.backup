extends CharacterBody2D

@export var speed: float = 200.0
@export var max_health: int = 100
@export var max_mana: int = 100

@onready var skill_manager = $SkillManager
@onready var camera = $Camera2D

var state_manager
var skill_indicator: Node2D

# 玩家状态
var health: int = 100
var mana: int = 100
var level: int = 1
var experience: int = 0

# 普攻系统
var basic_attack_damage: int = 25
var basic_attack_cooldown: float = 0.8
var basic_attack_range: float = 400
var basic_attack_ready: bool = true

func _physics_process(_delta: float) -> void:
	var input_vector = Vector2.ZERO
	input_vector.x = Input.get_action_strength("move_right") - Input.get_action_strength("move_left")
	input_vector.y = Input.get_action_strength("move_down") - Input.get_action_strength("move_up")
	input_vector = input_vector.normalized()

	velocity = input_vector * speed
	move_and_slide()

func _input(event: InputEvent) -> void:
	# 检查技能按键 1234
	if event is InputEventKey and event.pressed:
		match event.keycode:
			KEY_1:
				state_manager.handle_skill_key_input(0)
			KEY_2:
				state_manager.handle_skill_key_input(1)
			KEY_3:
				state_manager.handle_skill_key_input(2)
			KEY_4:
				state_manager.handle_skill_key_input(3)
			KEY_ESCAPE:
				state_manager.handle_escape_key()
	
	# 检查鼠标点击
	if event is InputEventMouseButton and event.pressed:
		var mouse_position = get_global_mouse_position()
		
		if event.button_index == MOUSE_BUTTON_LEFT:
			# 左键：尝试释放技能，如果没有技能选中则无效果
			if not state_manager.handle_left_click(mouse_position):
				# 状态管理器没有处理，说明是空闲状态，可以在这里添加其他逻辑
				pass
				
		elif event.button_index == MOUSE_BUTTON_RIGHT:
			# 右键：取消技能或执行普攻
			if not state_manager.handle_right_click(mouse_position):
				# 状态管理器没有处理（空闲状态），执行普攻
				perform_basic_attack(mouse_position)

# 这些方法现在由PlayerStateManager处理，为兼容性保留
func prepare_skill(skill_id: int) -> void:
	state_manager.handle_skill_key_input(skill_id)

func cancel_skill_selection() -> void:
	state_manager.cancel_skill_selection()

# 玩家状态管理
func take_damage(amount: int) -> void:
	health -= amount
	health = max(0, health)
	print("玩家受到 ", amount, " 点伤害，剩余血量: ", health)
	
	# 受伤视觉反馈
	show_damage_effect()
	
	if health <= 0:
		die()

func show_damage_effect() -> void:
	# 玩家受伤闪烁效果
	var damage_tween = create_tween()
	for i in range(3):
		damage_tween.tween_property(self, "modulate", Color.RED, 0.1)
		damage_tween.tween_property(self, "modulate", Color.WHITE, 0.1)
	
	# 轻微震动效果
	var original_pos = position
	var shake_tween = create_tween()
	for i in range(5):
		var offset = Vector2(randf_range(-3, 3), randf_range(-3, 3))
		shake_tween.tween_property(self, "position", original_pos + offset, 0.05)
	shake_tween.tween_property(self, "position", original_pos, 0.05)

func show_damage_number(amount: int, is_critical: bool = false) -> void:
	# 创建伤害数字
	var damage_label = Label.new()
	damage_label.script = preload("res://scripts/DamageNumber.gd")
	
	# 添加到UI层，确保在最前面显示
	var ui_layer = get_tree().current_scene.get_node("UI")
	if ui_layer:
		ui_layer.add_child(damage_label)
		
		# 转换世界坐标到屏幕坐标
		var screen_pos = get_viewport().get_camera_2d().get_screen_center_position()
		if get_viewport().get_camera_2d():
			screen_pos = global_position
		
		damage_label.setup(amount, screen_pos + Vector2(0, -30), is_critical)

func heal(amount: int) -> void:
	health += amount
	health = min(health, max_health)
	print("玩家恢复 ", amount, " 点生命值，当前血量: ", health)

func use_mana(amount: int) -> void:
	mana -= amount
	mana = max(0, mana)

func restore_mana(amount: int) -> void:
	mana += amount
	mana = min(mana, max_mana)

signal player_died

func die() -> void:
	print("玩家死亡!")
	# 禁用玩家输入
	set_physics_process(false)
	set_process_input(false)
	
	# 播放死亡动画
	var death_tween = create_tween()
	death_tween.tween_property(self, "modulate:a", 0.3, 0.5)
	death_tween.tween_property(self, "scale", Vector2(0.8, 0.8), 0.5)
	
	# 发出死亡信号
	player_died.emit()

func respawn() -> void:
	# 重置玩家状态
	health = max_health
	mana = max_mana
	
	# 重置外观
	modulate.a = 1.0
	scale = Vector2(1.0, 1.0)
	
	# 重新启用输入
	set_physics_process(true)
	set_process_input(true)
	
	# 移动到起始房间
	var dungeon_generator = get_tree().current_scene.get_node_or_null("DungeonGenerator")
	if dungeon_generator:
		var start_room = dungeon_generator.rooms.get(Vector2i(0, 0))
		if start_room:
			position = start_room.room_size / 2
			set_camera_limits(start_room.position, start_room.room_size)
			dungeon_generator.current_room = start_room
			dungeon_generator.show_room(Vector2i(0, 0))
	
	# 重置普攻冷却
	basic_attack_ready = true
	
	print("玩家重生!")

func perform_basic_attack(target_pos: Vector2) -> void:
	if not basic_attack_ready:
		print("普攻冷却中")
		return
	
	var distance = position.distance_to(target_pos)
	if distance > basic_attack_range:
		print("普攻距离过远")
		return
	
	print("发射普攻到: ", target_pos)
	
	# 创建普攻弹道
	create_basic_attack_projectile(target_pos)
	
	# 开始冷却
	basic_attack_ready = false
	var cooldown_timer = Timer.new()
	cooldown_timer.wait_time = basic_attack_cooldown
	cooldown_timer.one_shot = true
	cooldown_timer.timeout.connect(func(): 
		basic_attack_ready = true
		cooldown_timer.queue_free()
		print("普攻冷却完成")
	)
	add_child(cooldown_timer)
	cooldown_timer.start()

func create_basic_attack_projectile(target_pos: Vector2) -> void:
	# 创建普攻弹道
	var projectile = preload("res://Scenes/SkillEffect.tscn").instantiate()
	
	# 设置弹道属性
	projectile.position = position
	projectile.skill_type = "projectile"
	projectile.damage = basic_attack_damage
	projectile.speed = 500
	projectile.max_distance = basic_attack_range
	projectile.life_time = 3.0  # 设置生存时间作为备用
	
	# 计算方向
	var direction = (target_pos - position).normalized()
	projectile.direction = direction
	
	# 添加到技能效果容器
	var skill_effects = get_tree().current_scene.get_node_or_null("SkillEffects")
	if skill_effects:
		skill_effects.add_child(projectile)
		
		# 在添加后设置颜色（确保sprite已初始化）
		call_deferred("set_projectile_color", projectile)
	else:
		get_tree().current_scene.add_child(projectile)
		call_deferred("set_projectile_color", projectile)

func set_projectile_color(projectile: Node) -> void:
	# 设置普攻颜色为白色
	var sprite = projectile.get_node_or_null("Sprite2D")
	if sprite:
		sprite.modulate = Color.WHITE

# 每秒恢复魔法值
func _ready() -> void:
	var mana_regen_timer = Timer.new()
	mana_regen_timer.timeout.connect(_on_mana_regen)
	mana_regen_timer.wait_time = 1.0
	mana_regen_timer.autostart = true
	add_child(mana_regen_timer)
	
	# 初始化状态管理器
	var PlayerStateManagerClass = preload("res://scripts/PlayerStateManager.gd")
	state_manager = PlayerStateManagerClass.new(self)
	add_child(state_manager)
	
	# 获取技能指示器引用
	skill_indicator = get_tree().current_scene.get_node_or_null("SkillIndicator")

func _on_mana_regen() -> void:
	if mana < max_mana:
		restore_mana(5)  # 每秒恢复5点魔法

# 相机管理功能
func set_camera_limits(room_position: Vector2, room_size: Vector2) -> void:
	if camera:
		# 设置相机边界为当前房间
		camera.limit_left = int(room_position.x) - 50
		camera.limit_top = int(room_position.y) - 50  
		camera.limit_right = int(room_position.x + room_size.x) + 50
		camera.limit_bottom = int(room_position.y + room_size.y) + 50

func get_camera() -> Camera2D:
	return camera

func enable_camera_smoothing(enabled: bool = true) -> void:
	if camera:
		camera.position_smoothing_enabled = enabled
